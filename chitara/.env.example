# Database path (used inside Docker; leave unset for local dev)
DB_PATH=/app/data/db.sqlite3

# Strategy Pattern — set to "mock" for offline dev, "suno" for real API
GENERATOR_STRATEGY=mock

# Suno API credentials (only needed when GENERATOR_STRATEGY=suno)
SUNO_API_KEY=your_suno_api_key_here
SUNO_CALLBACK_URL=https://your-ngrok-url.ngrok-free.app/generation/suno/callback/

# Suno API base URL and timeout (optional overrides)
SUNO_API_BASE_URL=https://api.sunoapi.org/api/v1
SUNO_API_TIMEOUT=30

#Google Auth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret